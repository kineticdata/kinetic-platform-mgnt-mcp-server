# Location of OAS specs (optional)
KINETIC_OAS_DIR=./oas

# Optional sync source for scripts/sync-oas.js
KINETIC_OAS_SOURCE=../oas

# Tenant (space) auto-connect
KINETIC_SERVER_URL=https://<space-slug>.domain.com
KINETIC_USERNAME=tenant-username
KINETIC_PASSWORD=tenant-password

# System API (platform-level) auto-connect
KINETIC_SYSTEM_URL=https://platform.domain.com
KINETIC_SYSTEM_USERNAME=system-username
KINETIC_SYSTEM_PASSWORD=system-password
KINETIC_SYSTEM_AGENT_SLUG=system

# Allow self-signed certificates (dev only)
KINETIC_ALLOW_SELF_SIGNED=false

# HTTP/SSE mode
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_USER=admin
MCP_HTTP_PASS=secret
